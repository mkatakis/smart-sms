# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/smsplatform

# Express session secret — use a long random string in production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-secret

# GatewayAPI token — obtain from https://gatewayapi.com/app/tokens
GATEWAYAPI_TOKEN=your_gatewayapi_token_here

# Node environment
NODE_ENV=development
